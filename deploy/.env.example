# Copy to deploy/.env and fill in if building behind a corporate proxy.
# Local dev machines with direct internet should leave this unset.

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# Override the LLM model filename if your llama.cpp container expects a
# different one (e.g., custom GGUF):
# FEATCAT_LLM_MODEL=gemma-4-E2B-it-Q4_K_M.gguf

# Data directory on host containing Parquet files
# DATA_DIR=/path/to/your/data

# Port to expose featcat (default 8000)
# FEATCAT_PORT=8000

# Optional: auth token for API access
# SERVER_AUTH=
