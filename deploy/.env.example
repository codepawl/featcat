# Data directory on host containing Parquet files
DATA_DIR=/path/to/your/data

# Port to expose featcat (default 8000)
FEATCAT_PORT=8000

# LLM model (default gemma-4-E2B-it)
LLM_MODEL=gemma-4-E2B-it

# Optional: auth token for API access
SERVER_AUTH=

# Proxy settings (leave empty if not behind a proxy)
# Required for downloading GGUF model in setup.sh
HTTP_PROXY=
HTTPS_PROXY=
