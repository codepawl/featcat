# Profile: local
# Layered on top of deploy/.env.example by start-sandbox.sh.
# WSL2 / direct-internet developer boxes. No proxy.

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
no_proxy=localhost,127.0.0.1

# Compose build network mode. Empty string = use the default bridge network.
SANDBOX_BUILD_NETWORK=

# Skip image pulls? `false` lets compose pull what it doesn't have. The lab
# profile flips this to `true` so we fail fast when images are missing rather
# than hitting an unreachable registry through the corporate proxy.
SANDBOX_REQUIRE_CACHED_IMAGES=false
