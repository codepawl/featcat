# Profile: lab
# Layered on top of deploy/.env.example by start-sandbox.sh.
# FPT lab boxes behind the corporate proxy. Assumes FPT DNS is already in
# /etc/docker/daemon.json (the launcher does NOT edit daemon.json).

HTTP_PROXY=http://proxy.hcm.fpt.vn:80
HTTPS_PROXY=http://proxy.hcm.fpt.vn:80
NO_PROXY=llm,postgres,localhost,127.0.0.1,.fpt.vn
no_proxy=llm,postgres,localhost,127.0.0.1,.fpt.vn

# Build through the host network so the proxy is reachable from BuildKit.
SANDBOX_BUILD_NETWORK=host

# Fail fast if images are not already cached locally. Avoid silently hitting an
# unreachable registry through the proxy.
SANDBOX_REQUIRE_CACHED_IMAGES=true
